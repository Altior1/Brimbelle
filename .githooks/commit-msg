#!/usr/bin/env bash
#
# Brimbelle commit-msg hook
# Enforces: first line must match "S<n>-T<nn>: <subject>", max 72 chars.
# Exempts: Merge, Revert, fixup!, squash! commits.

msg_file="$1"
first_line=$(head -n1 "$msg_file")

case "$first_line" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*)
    exit 0
    ;;
esac

pattern='^S[0-9]+-T[0-9]+: .+'

if ! echo "$first_line" | grep -qE "$pattern"; then
  echo ""
  echo "Commit refuse : format de titre invalide."
  echo ""
  echo "Format attendu :"
  echo "    S<sprint>-T<ticket>: <sujet>"
  echo ""
  echo "Exemples :"
  echo "    S1-T01: init phx.gen.auth skeleton"
  echo "    S2-T03: add Sortable hook for block reorder"
  echo ""
  echo "Premiere ligne recue :"
  echo "    $first_line"
  echo ""
  exit 1
fi

if [ "${#first_line}" -gt 72 ]; then
  echo ""
  echo "Commit refuse : titre trop long (${#first_line} caracteres, max 72)."
  echo ""
  echo "Premiere ligne :"
  echo "    $first_line"
  echo ""
  exit 1
fi

exit 0
